{
  "PreToolUse": [
    {
      "matcher": "dispatch_sub_agent",
      "hooks": [
        {
          "type": "command",
          "command": "python ${CLAUDE_PLUGIN_ROOT}/hooks/scripts/budget_check.py"
        }
      ]
    },
    {
      "matcher": "mcp__pubmed-mcp__.*|mcp__clinicaltrials-mcp__.*|mcp__openfda-mcp__.*|mcp__polygon-mcp__.*|mcp__fda-adcomm-mcp__.*",
      "hooks": [
        {
          "type": "command",
          "command": "python ${CLAUDE_PLUGIN_ROOT}/hooks/scripts/budget_check.py"
        }
      ]
    }
  ],
  "PostToolUse": [
    {
      "matcher": "dispatch_sub_agent",
      "hooks": [
        {
          "type": "command",
          "command": "python ${CLAUDE_PLUGIN_ROOT}/hooks/scripts/log_observability.py"
        }
      ]
    },
    {
      "matcher": "mcp__pubmed-mcp__.*|mcp__clinicaltrials-mcp__.*|mcp__openfda-mcp__.*|mcp__polygon-mcp__.*|mcp__fda-adcomm-mcp__.*|mcp__compute-mcp__.*",
      "hooks": [
        {
          "type": "command",
          "command": "python ${CLAUDE_PLUGIN_ROOT}/hooks/scripts/log_observability.py"
        }
      ]
    }
  ]
}
