# macOS
.DS_Store

# Session state
.claude/

# Cursor IDE per-project config
.cursor/

# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.pytest_cache/
.venv/
venv/
.mypy_cache/
.ruff_cache/

# Modal workers runtime caches (openfigi_cache, scanner snapshots, etc.)
# Auto-created by modal_workers/shared/openfigi_resolver.py on import.
# Override location with OPENFIGI_CACHE_DIR env var (Modal sets this).
modal_workers/working/

# Cowork scheduled-task run logs (thesis_writer, signal_resolver, etc.).
# Tracked .md files in tasks/ are intentional; *.json runs are runtime output.
tasks/*.json

# Legacy unified_system reconcile / debug reports.
unified_system/unified_system/working/

# Node (should not appear at this level, but guard)
node_modules/

# Env files
.env
.env.*
!.env.example

# Vercel / Next build artifacts (dashboard is its own repo, but guard)
.vercel/
.next/
out/

# Dashboard lives in its own repo (marazuela/conan-dashboard)
dashboard/

# spec.md and CONAN_SCORING_METHOD.md now live in marazuela/conan-cowork-skills
# and are symlinked in locally. See that repo's README for the dual-repo + CONAN_ROOT setup.
/spec.md
/CONAN_SCORING_METHOD.md
*.md.bak
